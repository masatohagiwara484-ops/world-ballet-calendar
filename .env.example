# première — environment variables
# Copy to .env.local and fill in. The site renders fully without Supabase
# (bundled dataset floor); keys below unlock live data, ingestion & approval.

# Supabase (public — safe for the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — NEVER exposed to the client (seed, ingest, approval webhook)
SUPABASE_SERVICE_ROLE_KEY=

# LLM extraction in the ingest pipeline (claude-haiku)
ANTHROPIC_API_KEY=

# Telegram approval flow (optional — review:pending CLI works without it)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# Optional — venue maps upgrade from Leaflet to Google Maps when set
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
